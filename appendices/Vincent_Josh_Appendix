\begin{example}
The standard example of a 2-category is $\Cat$, the 2-category of categories. The objects are categories, the 1-morphisms are functors, and the 2-morphisms are natural transformations.
\end{example}
\begin{definition}
A (2,1)-category is a 2-category in which all the 2-morphisms are isomorphisms, that is, for every 2-morphism 
\[\begin{tikzcd}
	A && B
	\arrow[""{name=0, anchor=center, inner sep=0}, "g"', curve={height=6pt}, from=1-1, to=1-3]
	\arrow[""{name=1, anchor=center, inner sep=0}, "f", shift left=3, curve={height=-6pt}, from=1-1, to=1-3]
	\arrow["\alpha", Rightarrow, from=1, to=0]
\end{tikzcd}\]
there is an inverse 2-morphism
\[\begin{tikzcd}
	A && B
	\arrow[""{name=0, anchor=center, inner sep=0}, "g"', curve={height=6pt}, from=1-1, to=1-3]
	\arrow[""{name=1, anchor=center, inner sep=0}, "f", shift left=3, curve={height=-6pt}, from=1-1, to=1-3]
	\arrow["\beta"', Rightarrow, from=0, to=1]
\end{tikzcd}\]
such that $\beta \cdot \alpha = \id_f$ and $\alpha \cdot \beta = \id_g$.
\end{definition}
\begin{example}
The standard example of a (2,1)-category, which we will be considering a lot in this appendix, is $\Grpd$, the (2,1)-category of groupoids. The objects are groupoids, the 1-morphisms are functors, and the 2-morphisms are natural isomorphisms. 
\end{example}
\begin{definition}
Let $\mathcal{C}, \mathcal{D}$ be 2-categories, then a \emph{strict 2-functor} from $\mathcal{C} \to \mathcal{D}$ sends objects of $\mathcal{C}$ to objects of $\mathcal{D}$, 1-morphisms of $\mathcal{C}$ to 1-morphisms of $\mathcal{D}$, and 2-morphisms of $\mathcal{C}$ to 2-morphisms of $\mathcal{D}$, preserving domains, codomains, identity, and composition.
\end{definition}
\begin{definition}
A \emph{weak 2-functor} has the same definition as a strict 2-functor, without the requirement that it respects identity and composition of 1-morphisms. Instead, a weak 2-functor need only preserve identity and composition of 1-morphisms up to a natural isomorphism.
\end{definition}
