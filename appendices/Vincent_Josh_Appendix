\end{tikzcd}\]
We require that the vertical and horizontal compositions are "compatible" in the following diagram,
\[\begin{tikzcd}
	A && B && C
	\arrow[""{name=0, anchor=center, inner sep=0}, "h"'{pos=0.2}, shift right=3, curve={height=6pt}, from=1-1, to=1-3]
	\arrow[""{name=1, anchor=center, inner sep=0}, "f"{pos=0.2}, shift left=3, curve={height=-6pt}, from=1-1, to=1-3]
	\arrow[""{name=2, anchor=center, inner sep=0}, "g"'{pos=0.2}, from=1-1, to=1-3]
	\arrow[""{name=3, anchor=center, inner sep=0}, "v"'{pos=0.2}, from=1-3, to=1-5]
